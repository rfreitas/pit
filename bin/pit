#!/usr/bin/env bash
# pit — pi tree
# Creates a git worktree and launches pi inside it.
#
# Usage:
#   pit                  Create a worktree and launch pi
#   pit list             List pit worktrees for current repo
#   pit list --all       List all pit worktrees across all repos
#   pit clean            Remove orphaned registry entries
#   pit clean <id>       Remove a specific worktree by id

set -euo pipefail

REGISTRY="${HOME}/.pi/pit/registry.json"

# ── helpers ───────────────────────────────────────────────────────────────────

require_git_repo() {
  if ! git rev-parse --show-toplevel &>/dev/null; then
    echo "pit: not inside a git repository" >&2
    exit 1
  fi
}

repo_root() {
  git rev-parse --show-toplevel
}

# Generate a short random id (8 hex chars)
gen_id() {
  cat /dev/urandom | tr -dc 'a-f0-9' | head -c 8
}

# Convert a filesystem path to a Pi session bucket name
# e.g. C:\Users\ricfr\Repos\myrepo-wt-a1b2c3d4 → --C--Users-ricfr-Repos-myrepo-wt-a1b2c3d4--
path_to_bucket() {
  local p="$1"
  # Normalise to forward slashes, replace : and / with -, wrap with --..--
  echo "--$(echo "$p" | sed 's|\\|/|g' | sed 's|:|-|g' | sed 's|/|-|g')--"
}

# Get the Pi sessions root directory
sessions_dir() {
  echo "${HOME}/.pi/agent/sessions"
}

# Find the latest session file for a given worktree path
session_file_for() {
  local worktree="$1"
  local bucket
  bucket="$(sessions_dir)/$(path_to_bucket "$worktree")"
  if [[ -d "$bucket" ]]; then
    ls -t "$bucket"/*.jsonl 2>/dev/null | head -1
  fi
}

# Extract display name from a session file (mirrors what Pi shows)
session_name() {
  local file="$1"
  if [[ -z "$file" || ! -f "$file" ]]; then
    echo "(no session yet)"
    return
  fi

  # Latest session_info name
  local name
  name=$(grep '"type":"session_info"' "$file" | tail -1 | \
    python3 -c "import sys,json; d=json.loads(sys.stdin.read()); print(d.get('name',''))" 2>/dev/null || true)
  if [[ -n "$name" ]]; then
    echo "$name"
    return
  fi

  # First user message as preview
  local preview
  preview=$(grep '"role":"user"' "$file" | head -1 | \
    python3 -c "
import sys, json
d = json.loads(sys.stdin.read())
content = d.get('message', {}).get('content', [])
for c in content:
    if isinstance(c, dict) and c.get('type') == 'text':
        text = c['text'][:60].replace('\n', ' ')
        print(text)
        break
" 2>/dev/null || true)
  if [[ -n "$preview" ]]; then
    echo "$preview"
    return
  fi

  echo "(no session yet)"
}

# ── registry ──────────────────────────────────────────────────────────────────

registry_init() {
  mkdir -p "$(dirname "$REGISTRY")"
  if [[ ! -f "$REGISTRY" ]]; then
    echo '{"worktrees":[]}' > "$REGISTRY"
  fi
}

registry_add() {
  local id="$1" repo="$2" worktree="$3" branch="$4" created="$5"
  registry_init
  local tmp
  tmp=$(mktemp)
  python3 -c "
import sys, json
with open('$REGISTRY') as f:
    reg = json.load(f)
reg['worktrees'].append({
    'id': '$id',
    'repo': '$repo',
    'worktree': '$worktree',
    'branch': '$branch',
    'created': '$created'
})
print(json.dumps(reg, indent=2))
" > "$tmp" && mv "$tmp" "$REGISTRY"
}

registry_remove() {
  local id="$1"
  registry_init
  local tmp
  tmp=$(mktemp)
  python3 -c "
import sys, json
with open('$REGISTRY') as f:
    reg = json.load(f)
reg['worktrees'] = [w for w in reg['worktrees'] if w['id'] != '$id']
print(json.dumps(reg, indent=2))
" > "$tmp" && mv "$tmp" "$REGISTRY"
}

registry_entries() {
  registry_init
  python3 -c "
import json
with open('$REGISTRY') as f:
    reg = json.load(f)
for w in reg['worktrees']:
    print(w['id'] + '|' + w['repo'] + '|' + w['worktree'] + '|' + w['branch'] + '|' + w['created'])
"
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_new() {
  require_git_repo

  local id root branch worktree created
  id="$(gen_id)"
  root="$(repo_root)"
  branch="pi/${id}"
  worktree="${root%/*}/$(basename "$root")-wt-${id}"
  created="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  echo "pit: creating worktree"
  echo "  id:       $id"
  echo "  branch:   $branch"
  echo "  worktree: $worktree"

  git worktree add -b "$branch" "$worktree" HEAD

  registry_add "$id" "$root" "$worktree" "$branch" "$created"

  echo "pit: launching pi"
  cd "$worktree"
  exec pi
}

cmd_list() {
  local show_all="${1:-}"
  local current_repo=""

  if [[ "$show_all" != "--all" ]]; then
    if git rev-parse --show-toplevel &>/dev/null; then
      current_repo="$(repo_root)"
    fi
  fi

  registry_init

  local entries
  entries="$(registry_entries)"

  if [[ -z "$entries" ]]; then
    echo "no pit worktrees"
    return
  fi

  if [[ "$show_all" == "--all" ]]; then
    printf "%-10s  %-20s  %-40s  %s\n" "ID" "REPO" "SESSION NAME" "STATUS"
    printf "%-10s  %-20s  %-40s  %s\n" "----------" "--------------------" "----------------------------------------" "--------"
  else
    printf "%-10s  %-14s  %-40s  %s\n" "ID" "BRANCH" "SESSION NAME" "STATUS"
    printf "%-10s  %-14s  %-40s  %s\n" "----------" "--------------" "----------------------------------------" "--------"
  fi

  while IFS='|' read -r id repo worktree branch created; do
    [[ -z "$id" ]] && continue

    if [[ "$show_all" != "--all" && -n "$current_repo" && "$repo" != "$current_repo" ]]; then
      continue
    fi

    local status session_file name
    if [[ -d "$worktree" ]]; then
      status="active"
    else
      status="orphaned"
    fi

    session_file="$(session_file_for "$worktree")"
    name="$(session_name "$session_file")"

    if [[ "$show_all" == "--all" ]]; then
      local short_repo
      short_repo="$(basename "$repo")"
      printf "%-10s  %-20s  %-40s  %s\n" "$id" "$short_repo" "${name:0:40}" "$status"
    else
      printf "%-10s  %-14s  %-40s  %s\n" "$id" "$branch" "${name:0:40}" "$status"
    fi
  done <<< "$entries"
}

cmd_clean() {
  local id="${1:-}"

  if [[ -n "$id" ]]; then
    # Remove specific worktree
    local entry
    entry=$(registry_entries | grep "^${id}|" || true)
    if [[ -z "$entry" ]]; then
      echo "pit clean: no worktree with id '$id'" >&2
      exit 1
    fi

    local repo worktree branch created
    IFS='|' read -r _ repo worktree branch created <<< "$entry"

    if [[ -d "$worktree" ]]; then
      echo "pit: removing worktree: $worktree"
      git -C "$repo" worktree remove --force "$worktree"
    fi

    local short_branch="${branch#refs/heads/}"
    if git -C "$repo" show-ref --verify --quiet "refs/heads/${short_branch}" 2>/dev/null; then
      echo "pit: deleting branch: $short_branch"
      git -C "$repo" branch -D "$short_branch"
    fi

    registry_remove "$id"
    echo "pit: done"
  else
    # Remove orphaned entries
    local removed=0
    while IFS='|' read -r id repo worktree branch created; do
      [[ -z "$id" ]] && continue
      if [[ ! -d "$worktree" ]]; then
        echo "pit: removing orphaned entry: $id ($worktree)"
        registry_remove "$id"
        removed=$((removed + 1))
      fi
    done <<< "$(registry_entries)"

    if [[ $removed -eq 0 ]]; then
      echo "pit: no orphaned entries"
    else
      echo "pit: removed $removed orphaned entries"
    fi
  fi
}

# ── dispatch ──────────────────────────────────────────────────────────────────

case "${1:-}" in
  list)
    cmd_list "${2:-}"
    ;;
  clean)
    shift
    cmd_clean "${1:-}"
    ;;
  -h|--help)
    sed -n '2,8p' "$0" | sed 's/^# //'
    ;;
  "")
    cmd_new
    ;;
  *)
    echo "pit: unknown command '$1'" >&2
    exit 1
    ;;
esac

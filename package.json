{
  "name": "@ricfr/pi-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pi agent extensions, scripts, and tooling",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "typecheck": "tsc",
    "lint": "node --experimental-strip-types node_modules/.bin/eslint 'pit/**/*.ts' && node --experimental-strip-types pit/scripts/check-no-disable.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@sinclair/typebox": "^0.34.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-plugin-functional": "^9.0.5",
    "eslint-plugin-import-x": "^4.16.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "effect": "^3.21.2"
  }
}

{
  "name": "@ricfr/pi-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pi agent extensions, scripts, and tooling",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "workspaces": [
    "pit",
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true; find node_modules/node-pty/prebuilds -name 'spawn-helper' -exec chmod +x {} \\; 2>/dev/null || true",
    "typecheck": "tsc",
    "lint": "tsx node_modules/.bin/eslint 'pit/**/*.ts' && tsx pit/scripts/check-no-disable.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@sinclair/typebox": "^0.34.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-plugin-functional": "^9.0.5",
    "eslint-plugin-import-x": "^4.16.2",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  }
}
